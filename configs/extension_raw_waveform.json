{
  "project": "csc4005-lab3-urbansound-1dcnn",
  "run_name": "extension_raw_waveform_1dcnn",
  "model_name": "raw_1dcnn",
  "feature_type": "raw",
  "sample_rate": 16000,
  "duration": 4.0,
  "n_fft": 1024,
  "hop_length": 512,
  "n_mfcc": 40,
  "n_mels": 64,
