  "dropout": 0.4,
  "epochs": 15,
  "batch_size": 16,
  "lr": 0.0005,
  "weight_decay": 0.0001,
  "optimizer": "adamw",
  "scheduler": "plateau",
  "patience": 5,
  "train_folds": [1, 2, 3, 4, 5, 6, 7, 8],
  "val_folds": [9],
  "test_folds": [10],
  "max_train_per_class": 120,
  "max_eval_per_class": 50,
  "augment": true,
  "cache_dir": ".cache/features_raw",
  "num_workers": 0,
  "seed": 42,
  "device": "auto",
  "use_wandb": true,
  "wandb_mode": "online"
}
